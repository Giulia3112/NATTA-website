# ─── Banco de Dados ───────────────────────────────────────────
DATABASE_URL=mysql://user:password@host:3306/dbname

# ─── Firebase Admin SDK (Backend) ────────────────────────────
# Obtenha em: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ─── Admin ────────────────────────────────────────────────────
# Email do usuário que terá role=admin automaticamente ao fazer login
ADMIN_EMAIL=alvaresgiulia@gmail.com

# ─── Firebase Client SDK (Frontend) ──────────────────────────
# Obtenha em: Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# ─── Opcional ─────────────────────────────────────────────────
PORT=3000
